          <mxGeometry x="680" y="90" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="v4" value="4. ANN helps find nearby candidates.&amp;#10;ANN = approximate nearest neighbor." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1020" y="90" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="v5" value="5. If you ask for exact wording, MNO can open the wording receipt lane." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="280" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="v6" value="6. If old and corrected reviewed cards exist, MNO prefers the current reviewed one." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="470" y="280" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="v7" value="7. MNO builds a bounded evidence bundle, not a giant raw dump." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="850" y="280" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="v8" value="8. MNO answers, abstains, or asks you to clarify." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="285" y="470" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="v9" value="9. New risky memory still goes to proposal/review, not straight to truth." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5f1;strokeColor=#b8549e;" vertex="1" parent="1">
          <mxGeometry x="655" y="470" width="340" height="90" as="geometry" />
        </mxCell>
        <mxCell id="v10" value="Words to know&amp;#10;MCP = Model Context Protocol&amp;#10;ANN = approximate nearest neighbor&amp;#10;STM = short-term memory&amp;#10;WSS = work-session scratchpad" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="490" y="630" width="320" height="100" as="geometry" />
        </mxCell>
