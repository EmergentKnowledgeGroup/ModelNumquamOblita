  <diagram id="launch-pipeline-caveman" name="Caveman Pipeline">
    <mxGraphModel dx="1450" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="q1" value="1. Click the starter file or open the app." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="q2" value="2. Pick files, folders, or an existing store.&amp;#10;You can mix folders and single files." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="360" y="90" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="q3" value="3. MNO cleans the pile and makes atoms.&amp;#10;Atoms = small evidence pieces." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#c97b63;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="q4" value="4. MNO also keeps a wording receipt for quote checks." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#c97b63;" vertex="1" parent="1">
          <mxGeometry x="1020" y="90" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="q5" value="5. MNO builds rough story cards.&amp;#10;Rough = draft, not trusted yet." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#c97b63;" vertex="1" parent="1">
          <mxGeometry x="160" y="280" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="q6" value="6. Assistant/agent can help clean the draft, but it stays draft-only." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5f1;strokeColor=#b8549e;" vertex="1" parent="1">
          <mxGeometry x="500" y="280" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="q7" value="7. Human decides what becomes trusted memory." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="880" y="280" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="q8" value="8. Corrected reviewed cards stay linked so old vs current truth is clearer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="260" y="470" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="q9" value="9. Reviewed memory goes live in the runtime." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="470" width="280" height="80" as="geometry" />
        </mxCell>
