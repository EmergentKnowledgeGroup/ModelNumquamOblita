        <mxCell id="c2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9d9;strokeColor=#c97b63;" value="2. MNO cleans the pile and keeps a wording receipt.&amp;#10;Receipt = the original cleaned wording for quote checks." vertex="1">
