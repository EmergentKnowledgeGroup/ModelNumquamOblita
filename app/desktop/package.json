{
  "name": "modelnumquamoblita-desktop-shell",
  "version": "0.2.0",
  "private": true,
  "author": "ProfessahX",
  "description": "Electron shell for the standalone ModelNumquamOblita runtime UI",
  "main": "main.js",
  "scripts": {
    "desktop:dev": "electron .",
    "desktop:test": "node --test *.test.cjs",
    "desktop:build-assets": "bash build/generate_macos_icon.sh",
    "desktop:bundle-runtime": "node run-python.cjs build_managed_runtime.py",
    "desktop:clean-pack-output": "node clean-pack-output.cjs",
    "desktop:pack:dir": "npm run desktop:clean-pack-output && npm run desktop:build-assets && npm run desktop:bundle-runtime && node run-electron-builder.cjs --dir --publish never --unsigned-mac-local",
    "desktop:pack:dir:signed": "npm run desktop:clean-pack-output && npm run desktop:build-assets && npm run desktop:bundle-runtime && node run-electron-builder.cjs --dir --publish never",
    "desktop:pack:mac": "npm run desktop:clean-pack-output && npm run desktop:build-assets && npm run desktop:bundle-runtime && node run-electron-builder.cjs --mac dmg zip --publish never",
    "desktop:pack:linux": "npm run desktop:clean-pack-output && npm run desktop:bundle-runtime && node run-electron-builder.cjs --linux AppImage --publish never"
  },
  "engines": {
    "node": ">=22"
  },
  "build": {
    "appId": "com.professahx.modelnumquamoblita.desktop",
    "productName": "ModelNumquamOblita",
    "afterPack": "./after-pack.cjs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "boot.html",
      "boot.css",
      "boot.js",
      "runtime-controller.cjs",
      "tray-controller.cjs",
      "runtime-bundle.manifest.json",
      "package.json",
      "!*.test.cjs"
    ],
    "extraResources": [
      {
        "from": "../../engine",
        "to": "mno_bundle/engine"
      },
      {
        "from": "../../tools",
        "to": "mno_bundle/tools"
      },
      {
        "from": "../../runtime",
        "to": "mno_bundle/runtime"
      },
      {
        "from": "build/runtime/python",
        "to": "mno_bundle/runtime/python"
      },
      {
        "from": "../../pyproject.toml",
        "to": "mno_bundle/pyproject.toml"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "41.7.1",
    "electron-builder": "26.8.1"
  }
}
